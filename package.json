{
  "name": "pds",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A from-scratch, teaching-oriented Bluesky PDS in TanStack Start.",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.14",
    "@ipld/car": "^5.3.3",
    "@ipld/dag-cbor": "^9.2.2",
    "@noble/curves": "^1.7.0",
    "@noble/hashes": "^1.6.1",
    "@shikijs/rehype": "^1.24.0",
    "@tanstack/react-router": "^1.97.0",
    "@tanstack/react-start": "^1.97.0",
    "@tanstack/router-plugin": "^1.97.0",
    "drizzle-orm": "^0.36.4",
    "jose": "^5.9.6",
    "multiformats": "^13.3.1",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.24.0",
    "unified": "^11.0.5",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0-beta.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0-beta.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
