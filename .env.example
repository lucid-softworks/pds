# Connection string. Three accepted forms:
#   pglite                — in-process Postgres in ./.pglite (default)
#   pglite:./some/path    — in-process Postgres at the given directory
#   postgres://...        — any external Postgres (Neon, Supabase, local)
DATABASE_URL=pglite

# The public origin of this PDS. Used to issue did:web identifiers, build
# absolute URLs in lexicon responses, and validate redirect URIs. In dev,
# something like http://localhost:3000 is fine.
PDS_PUBLIC_URL=http://localhost:3000

# The hostname (no scheme) shown to clients as the service's authority. For
# did:web it must match PDS_PUBLIC_URL's host.
PDS_HOSTNAME=localhost

# JWT signing secret. 64 random bytes, hex-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
PDS_JWT_SECRET=replace-me-with-64-random-bytes

# Repo signing key for the PDS itself (k256 / secp256k1). Generated by
# `pnpm pds:keygen` (a script that lands in chapter 12). Stored hex.
PDS_REPO_SIGNING_KEY=

# ---- Email backend (chapter 13 + 18) ----
# 'console' (default) logs every send to stdout. 'http-json' POSTs to a
# transactional provider over JSON; set URL + token + from.
# PDS_EMAIL_BACKEND=console
# PDS_EMAIL_FROM=noreply@pds.example
# PDS_EMAIL_HTTP_URL=https://api.resend.com/emails
# PDS_EMAIL_HTTP_TOKEN=
# PDS_EMAIL_HTTP_FLAVOR=generic    # 'generic' | 'postmark'

# ---- Admin web UI (chapter 19) ----
# Handle of the account that gates /admin. When unset, the /admin pages 404
# (the operator surface is entirely opt-in). When set, the operator logs in
# as that account through the regular session flow; /admin re-checks the
# account's *current* handle equals this value on every request, so a
# handle rotation immediately revokes UI access. The matching XRPC admin
# surface (com.atproto.admin.*) is separately gated by HTTP Basic +
# PDS_ADMIN_PASSWORD_HASH for automation use.
# PDS_ADMIN_HANDLE=alice.test

# ---- DPoP replay store (chapter 21) ----
# Backend that remembers DPoP `jti` values inside the 60s spec window so a
# captured proof can't be replayed. 'in-memory' (default) is a single-
# process Map — fine for one PDS process. 'redis' selects a stub that
# documents the SETNX EX 60 pattern and throws on first use; swap in a
# real Redis client if you run multi-replica.
# PDS_DPOP_REPLAY_STORE=in-memory
